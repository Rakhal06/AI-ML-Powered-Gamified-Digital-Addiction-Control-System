<ScrollView xmlns:android="http://schemas.android.com/apk/res/android" xmlns:app="http://schemas.android.com/apk/res-auto" android:layout_width="match_parent" android:layout_height="match_parent" android:background="#0D0D1A" android:fillViewport="true">
    <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content" android:orientation="vertical" android:padding="16dp">
        <!--  Header  -->
        <TextView android:layout_width="match_parent" android:layout_height="wrap_content" android:text="🧠 SoftControl AI" android:textColor="#FFFFFF" android:textSize="26sp" android:textStyle="bold" android:gravity="center" android:paddingTop="16dp" android:paddingBottom="4dp"/>
        <TextView android:layout_width="match_parent" android:layout_height="wrap_content" android:text="Digital Addiction Control System" android:textColor="#9E9EC8" android:textSize="13sp" android:gravity="center" android:paddingBottom="16dp"/>
        <!--  Demo Simulation  -->
        <androidx.cardview.widget.CardView android:layout_width="match_parent" android:layout_height="wrap_content" android:layout_marginBottom="12dp" app:cardBackgroundColor="#1A1A0A" app:cardCornerRadius="12dp" app:cardElevation="4dp">
            <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content" android:orientation="vertical" android:padding="12dp">
                <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="🎮 Demo Simulation Mode" android:textColor="#FACC15" android:textSize="13sp" android:textStyle="bold" android:paddingBottom="8dp"/>
                <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content" android:orientation="horizontal">
                    <Button android:id="@+id/btnSimGood" android:layout_width="0dp" android:layout_height="40dp" android:layout_weight="1" android:text="😴 Good" android:textColor="#FFFFFF" android:backgroundTint="#059669" android:textSize="12sp" android:layout_marginEnd="4dp"/>
                    <Button android:id="@+id/btnSimDefault" android:layout_width="0dp" android:layout_height="40dp" android:layout_weight="1" android:text="😤 Default" android:textColor="#FFFFFF" android:backgroundTint="#B45309" android:textSize="12sp" android:layout_marginEnd="4dp"/>
                    <Button android:id="@+id/btnSimBad" android:layout_width="0dp" android:layout_height="40dp" android:layout_weight="1" android:text="💀 Bad" android:textColor="#FFFFFF" android:backgroundTint="#DC2626" android:textSize="12sp"/>
                </LinearLayout>
            </LinearLayout>
        </androidx.cardview.widget.CardView>
        <!--  Monster Card  -->
        <androidx.cardview.widget.CardView android:layout_width="match_parent" android:layout_height="wrap_content" android:layout_marginBottom="12dp" app:cardBackgroundColor="#1A1A2E" app:cardCornerRadius="16dp" app:cardElevation="8dp">
            <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content" android:orientation="vertical" android:padding="16dp" android:gravity="center">
                <TextView android:id="@+id/tvMonster" android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="😴" android:textSize="64sp"/>
                <TextView android:id="@+id/tvMonsterLabel" android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="Addiction Monster — Level 0" android:textColor="#9E9EC8" android:textSize="13sp" android:paddingTop="4dp"/>
                <TextView android:id="@+id/tvLabel" android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="FOCUSED" android:textColor="#00FF88" android:textSize="18sp" android:textStyle="bold" android:paddingTop="8dp"/>
                <TextView android:id="@+id/tvConfidence" android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="Ensemble confidence: —" android:textColor="#9E9EC8" android:textSize="11sp" android:paddingTop="4dp"/>
            </LinearLayout>
        </androidx.cardview.widget.CardView>
        <!--  Scores Row  -->
        <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content" android:orientation="horizontal" android:layout_marginBottom="12dp">
            <androidx.cardview.widget.CardView android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1" android:layout_marginEnd="6dp" app:cardBackgroundColor="#1A1A2E" app:cardCornerRadius="12dp">
                <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content" android:orientation="vertical" android:padding="12dp" android:gravity="center">
                    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="Self Control" android:textColor="#9E9EC8" android:textSize="11sp"/>
                    <TextView android:id="@+id/tvSelfControl" android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="100" android:textColor="#00FF88" android:textSize="32sp" android:textStyle="bold"/>
                    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="/ 100" android:textColor="#9E9EC8" android:textSize="11sp"/>
                </LinearLayout>
            </androidx.cardview.widget.CardView>
            <androidx.cardview.widget.CardView android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1" android:layout_marginStart="6dp" app:cardBackgroundColor="#1A1A2E" app:cardCornerRadius="12dp">
                <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content" android:orientation="vertical" android:padding="12dp" android:gravity="center">
                    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="Relapse Risk" android:textColor="#9E9EC8" android:textSize="11sp"/>
                    <TextView android:id="@+id/tvRisk" android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="0%" android:textColor="#FF4444" android:textSize="32sp" android:textStyle="bold"/>
                    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="risk level" android:textColor="#9E9EC8" android:textSize="11sp"/>
                </LinearLayout>
            </androidx.cardview.widget.CardView>
        </LinearLayout>
        <!--  Stats Row  -->
        <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content" android:orientation="horizontal" android:layout_marginBottom="12dp">
            <androidx.cardview.widget.CardView android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1" android:layout_marginEnd="6dp" app:cardBackgroundColor="#1A1A2E" app:cardCornerRadius="12dp">
                <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content" android:orientation="vertical" android:padding="12dp" android:gravity="center">
                    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="User Type" android:textColor="#9E9EC8" android:textSize="11sp"/>
                    <TextView android:id="@+id/tvCluster" android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="—" android:textColor="#A78BFA" android:textSize="14sp" android:textStyle="bold" android:gravity="center"/>
                </LinearLayout>
            </androidx.cardview.widget.CardView>
            <androidx.cardview.widget.CardView android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1" android:layout_marginStart="6dp" app:cardBackgroundColor="#1A1A2E" app:cardCornerRadius="12dp">
                <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content" android:orientation="vertical" android:padding="12dp" android:gravity="center">
                    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="Weekly Forecast" android:textColor="#9E9EC8" android:textSize="11sp"/>
                    <TextView android:id="@+id/tvWeekly" android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="—" android:textColor="#FACC15" android:textSize="14sp" android:textStyle="bold" android:gravity="center"/>
                </LinearLayout>
            </androidx.cardview.widget.CardView>
        </LinearLayout>
        <!--  Binge Alert  -->
        <androidx.cardview.widget.CardView android:id="@+id/cardBinge" android:layout_width="match_parent" android:layout_height="wrap_content" android:layout_marginBottom="12dp" android:visibility="gone" app:cardBackgroundColor="#2D0A0A" app:cardCornerRadius="12dp">
            <TextView android:id="@+id/tvBingeAlert" android:layout_width="match_parent" android:layout_height="wrap_content" android:padding="14dp" android:text="🚨 BINGE SESSION DETECTED" android:textColor="#FF4444" android:textSize="13sp" android:textStyle="bold" android:gravity="center"/>
        </androidx.cardview.widget.CardView>
        <!--  SHAP Card  -->
        <androidx.cardview.widget.CardView android:layout_width="match_parent" android:layout_height="wrap_content" android:layout_marginBottom="12dp" app:cardBackgroundColor="#1A1A2E" app:cardCornerRadius="12dp">
            <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content" android:orientation="vertical" android:padding="16dp">
                <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="🔬 Explainable AI (SHAP)" android:textColor="#60A5FA" android:textSize="14sp" android:textStyle="bold" android:paddingBottom="8dp"/>
                <TextView android:id="@+id/tvTopFactor" android:layout_width="match_parent" android:layout_height="wrap_content" android:text="Top contributing factor: —" android:textColor="#CCCCCC" android:textSize="13sp"/>
                <TextView android:id="@+id/tvShapDetails" android:layout_width="match_parent" android:layout_height="wrap_content" android:text="" android:textColor="#9E9EC8" android:textSize="12sp" android:paddingTop="4dp" android:lineSpacingExtra="3dp"/>
            </LinearLayout>
        </androidx.cardview.widget.CardView>
        <!--  AI Insight Card  -->
        <androidx.cardview.widget.CardView android:layout_width="match_parent" android:layout_height="wrap_content" android:layout_marginBottom="12dp" app:cardBackgroundColor="#1A1A2E" app:cardCornerRadius="12dp">
            <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content" android:orientation="vertical" android:padding="16dp">
                <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="🧠 AI Insight" android:textColor="#A78BFA" android:textSize="14sp" android:textStyle="bold" android:paddingBottom="8dp"/>
                <TextView android:id="@+id/tvInsight" android:layout_width="match_parent" android:layout_height="wrap_content" android:text="Tap Analyze to get your AI insight..." android:textColor="#CCCCCC" android:textSize="13sp" android:lineSpacingExtra="4dp"/>
            </LinearLayout>
        </androidx.cardview.widget.CardView>
        <!--  Coach Tip Card  -->
        <androidx.cardview.widget.CardView android:layout_width="match_parent" android:layout_height="wrap_content" android:layout_marginBottom="16dp" app:cardBackgroundColor="#1A1A2E" app:cardCornerRadius="12dp">
            <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content" android:orientation="vertical" android:padding="16dp">
                <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="💡 Coach Tip" android:textColor="#FACC15" android:textSize="14sp" android:textStyle="bold" android:paddingBottom="8dp"/>
                <TextView android:id="@+id/tvCoachTip" android:layout_width="match_parent" android:layout_height="wrap_content" android:text="Your personalized tip will appear here..." android:textColor="#CCCCCC" android:textSize="13sp" android:lineSpacingExtra="4dp"/>
            </LinearLayout>
        </androidx.cardview.widget.CardView>
        <!--  Core Action Buttons  -->
        <Button android:id="@+id/btnAnalyze" android:layout_width="match_parent" android:layout_height="56dp" android:text="🔍 ANALYZE MY BEHAVIOR" android:textColor="#FFFFFF" android:backgroundTint="#7C3AED" android:layout_marginBottom="10dp" android:textStyle="bold"/>
        <Button android:id="@+id/btnFocus" android:layout_width="match_parent" android:layout_height="56dp" android:text="🎯 START FOCUS MODE" android:textColor="#FFFFFF" android:backgroundTint="#059669" android:layout_marginBottom="10dp" android:textStyle="bold"/>
        <Button android:id="@+id/btnReport" android:layout_width="match_parent" android:layout_height="56dp" android:text="📊 VIEW REPORT" android:textColor="#FFFFFF" android:backgroundTint="#1D4ED8" android:layout_marginBottom="10dp" android:textStyle="bold"/>
        <Button android:id="@+id/btnCoach" android:layout_width="match_parent" android:layout_height="56dp" android:text="🤖 AI COACH CHAT" android:textColor="#FFFFFF" android:backgroundTint="#B45309" android:layout_marginBottom="10dp" android:textStyle="bold"/>
        <!--  Feature 4/5/7 Navigation Buttons  -->
        <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content" android:orientation="horizontal" android:layout_marginBottom="24dp">
            <Button android:id="@+id/btnGamification" android:layout_width="0dp" android:layout_height="48dp" android:layout_weight="1" android:text="🏆 XP" android:textColor="#FFFFFF" android:backgroundTint="#7C3AED" android:textSize="12sp" android:layout_marginEnd="5dp"/>
            <Button android:id="@+id/btnLeaderboard" android:layout_width="0dp" android:layout_height="48dp" android:layout_weight="1" android:text="🥇 Rank" android:textColor="#FFFFFF" android:backgroundTint="#B45309" android:textSize="12sp" android:layout_marginEnd="5dp"/>
            <Button android:id="@+id/btnAnalytics" android:layout_width="0dp" android:layout_height="48dp" android:layout_weight="1" android:text="📈 Trends" android:textColor="#FFFFFF" android:backgroundTint="#1D4ED8" android:textSize="12sp"/>
        </LinearLayout>
    </LinearLayout>
</ScrollView>